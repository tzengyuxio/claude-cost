#!/bin/bash
# claude-cost-collect — Collect usage from enabled providers into SQLite
# Designed to be run daily by launchd/systemd; handles backfill for missed days.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=../lib/claude-cost-common.sh
_COMMON="$SCRIPT_DIR/../lib/claude-cost/claude-cost-common.sh"
[ -f "$_COMMON" ] || _COMMON="$SCRIPT_DIR/../lib/claude-cost-common.sh"
# shellcheck source=/dev/null
. "$_COMMON"

# Source provider fetchers
_FETCHERS_DIR="$SCRIPT_DIR/../lib/claude-cost/fetchers"
[ -d "$_FETCHERS_DIR" ] || _FETCHERS_DIR="$SCRIPT_DIR/../lib/fetchers"
# shellcheck source=/dev/null
. "$_FETCHERS_DIR/claude.sh"
# shellcheck source=/dev/null
. "$_FETCHERS_DIR/codex.sh"

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "$LOG"
}

# --- Lock mechanism ---
cleanup_lock() {
    rmdir "$LOCK_DIR" 2>/dev/null || true
}
if ! mkdir "$LOCK_DIR" 2>/dev/null; then
    log "ERROR: Another instance is running (lock exists). Exiting."
    exit 1
fi
trap cleanup_lock EXIT

# --- Ensure DB and schema exist (with migration) ---
init_db() {
    sqlite3 "$DB" <<'SQL'
CREATE TABLE IF NOT EXISTS daily_usage (
    date       TEXT NOT NULL,
    provider   TEXT NOT NULL DEFAULT 'claude',
    model      TEXT NOT NULL,
    input_tokens          INTEGER DEFAULT 0,
    output_tokens         INTEGER DEFAULT 0,
    cache_creation_tokens INTEGER DEFAULT 0,
    cache_read_tokens     INTEGER DEFAULT 0,
    cost_usd              REAL DEFAULT 0.0,
    PRIMARY KEY (date, provider, model)
);

CREATE TABLE IF NOT EXISTS collect_metadata (
    key   TEXT PRIMARY KEY,
    value TEXT
);
SQL

    # Migrate: add provider column if missing (old schema had PK (date, model))
    local has_provider
    has_provider=$(sqlite3 "$DB" "SELECT COUNT(*) FROM pragma_table_info('daily_usage') WHERE name='provider';")
    if [ "$has_provider" -eq 0 ]; then
        log "INFO: Migrating schema: adding provider column to daily_usage"
        sqlite3 "$DB" <<'SQL'
BEGIN;
CREATE TABLE daily_usage_new (
    date       TEXT NOT NULL,
    provider   TEXT NOT NULL DEFAULT 'claude',
    model      TEXT NOT NULL,
    input_tokens          INTEGER DEFAULT 0,
    output_tokens         INTEGER DEFAULT 0,
    cache_creation_tokens INTEGER DEFAULT 0,
    cache_read_tokens     INTEGER DEFAULT 0,
    cost_usd              REAL DEFAULT 0.0,
    PRIMARY KEY (date, provider, model)
);
INSERT INTO daily_usage_new
    SELECT date, 'claude', model,
           input_tokens, output_tokens,
           cache_creation_tokens, cache_read_tokens,
           cost_usd
    FROM daily_usage;
DROP TABLE daily_usage;
ALTER TABLE daily_usage_new RENAME TO daily_usage;
COMMIT;
SQL
        # Migrate watermark key
        sqlite3 "$DB" "UPDATE collect_metadata SET key='last_collected_date:claude' WHERE key='last_collected_date';"
        log "INFO: Schema migration complete."
    fi
}

mkdir -p "$(dirname "$LOG")"
init_db

YESTERDAY=$(yesterday)

# --- Provider loop ---
if [[ -z "$ENABLED_PROVIDERS" ]]; then
    log "WARNING: ENABLED_PROVIDERS is empty, nothing to collect."
    exit 0
fi

for PROVIDER in $ENABLED_PROVIDERS; do
    WATERMARK_KEY="last_collected_date:${PROVIDER}"
    LAST_COLLECTED=$(sqlite3 "$DB" "SELECT value FROM collect_metadata WHERE key='${WATERMARK_KEY}';" 2>/dev/null || echo "")

    if [[ -n "$LAST_COLLECTED" && ! "$LAST_COLLECTED" < "$YESTERDAY" ]]; then
        log "INFO: [${PROVIDER}] Already up to date (last_collected=$LAST_COLLECTED, yesterday=$YESTERDAY). Skipping."
        continue
    fi

    log "INFO: [${PROVIDER}] Starting collection. last_collected=${LAST_COLLECTED:-<none>}, yesterday=$YESTERDAY"

    # Validate fetcher function exists before calling
    if ! declare -f "fetch_${PROVIDER}" > /dev/null 2>&1; then
        log "ERROR: [${PROVIDER}] No fetcher function 'fetch_${PROVIDER}' found."
        continue
    fi

    # Call the appropriate fetcher function
    ROWS=$(fetch_${PROVIDER} "$LAST_COLLECTED" "$YESTERDAY" 2>> "$LOG") || {
        log "ERROR: [${PROVIDER}] Fetcher failed. Skipping provider."
        continue
    }

    if [ -z "$ROWS" ]; then
        log "INFO: [${PROVIDER}] No new data to insert."
        continue
    fi

    ROWS_BEFORE=$(sqlite3 "$DB" "SELECT COUNT(*) FROM daily_usage WHERE provider='${PROVIDER}';")

    if ! {
        echo "BEGIN;"
        while IFS=$'\t' read -r dt prov model input output cache_create cache_read cost; do
            # Validate date format
            if [[ ! "$dt" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then
                log "WARNING: [${PROVIDER}] Skipping row with invalid date: '$dt'"
                continue
            fi
            # Escape string fields
            model_escaped="${model//\'/\'\'}"
            prov_escaped="${prov//\'/\'\'}"
            # Sanitize numeric fields: replace non-numeric values with 0
            [[ "$input"        =~ ^-?[0-9]+(\.[0-9]+)?$ ]] || { log "WARNING: [${PROVIDER}] Non-numeric input_tokens '$input', using 0"; input=0; }
            [[ "$output"       =~ ^-?[0-9]+(\.[0-9]+)?$ ]] || { log "WARNING: [${PROVIDER}] Non-numeric output_tokens '$output', using 0"; output=0; }
            [[ "$cache_create" =~ ^-?[0-9]+(\.[0-9]+)?$ ]] || { log "WARNING: [${PROVIDER}] Non-numeric cache_creation_tokens '$cache_create', using 0"; cache_create=0; }
            [[ "$cache_read"   =~ ^-?[0-9]+(\.[0-9]+)?$ ]] || { log "WARNING: [${PROVIDER}] Non-numeric cache_read_tokens '$cache_read', using 0"; cache_read=0; }
            [[ "$cost"         =~ ^-?[0-9]+(\.[0-9]+)?$ ]] || { log "WARNING: [${PROVIDER}] Non-numeric cost_usd '$cost', using 0"; cost=0; }
            echo "INSERT OR REPLACE INTO daily_usage (date, provider, model, input_tokens, output_tokens, cache_creation_tokens, cache_read_tokens, cost_usd) VALUES ('$dt', '$prov_escaped', '$model_escaped', $input, $output, $cache_create, $cache_read, $cost);"
        done <<< "$ROWS"
        echo "COMMIT;"
    } | sqlite3 "$DB"; then
        log "ERROR: [${PROVIDER}] DB transaction failed."
        continue
    fi

    ROWS_AFTER=$(sqlite3 "$DB" "SELECT COUNT(*) FROM daily_usage WHERE provider='${PROVIDER}';")
    INSERTED=$((ROWS_AFTER - ROWS_BEFORE))
    MAX_DATE=$(sqlite3 "$DB" "SELECT MAX(date) FROM daily_usage WHERE provider='${PROVIDER}' AND date <= '$YESTERDAY';")

    if [ -n "$MAX_DATE" ]; then
        sqlite3 "$DB" "INSERT OR REPLACE INTO collect_metadata (key, value) VALUES ('${WATERMARK_KEY}', '$MAX_DATE');"
        log "INFO: [${PROVIDER}] Upserted data ($INSERTED new rows, total $ROWS_AFTER). Watermark updated to $MAX_DATE."
    else
        log "INFO: [${PROVIDER}] No rows inserted."
    fi
done
